# ─────────────────────────────────────────────────────────────
#  Sandbox Playground — Frontend environment variables
#  Copy to `.env.local` and fill in for a real deployment.
#  With the defaults below the SPA runs fully in DEMO/MOCK mode
#  (no backend, no Entra tenant required).
# ─────────────────────────────────────────────────────────────

# Backend base URL (FastAPI). Only used when VITE_USE_MOCKS=false.
VITE_API_BASE_URL=http://localhost:8000/api

# Use the in-browser mock API instead of a live backend.
# true  -> realistic fake data, scans progress on a simulated clock
# false -> calls the real FastAPI backend at VITE_API_BASE_URL
VITE_USE_MOCKS=true

# Auth provider: "mock" (instant demo login) or "msal" (real Entra ID).
VITE_AUTH_MODE=mock

# Microsoft Entra ID — only required when VITE_AUTH_MODE=msal
VITE_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
VITE_ENTRA_REDIRECT_URI=http://localhost:5173
VITE_API_SCOPE=api://00000000-0000-0000-0000-000000000000/access_as_user
